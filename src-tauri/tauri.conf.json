{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "伦敦金银行情",
  "version": "0.1.0",
  "identifier": "com.precious-metals-tracker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "伦敦金银实时行情",
        "width": 700,
        "height": 560,
        "resizable": true,
        "center": true
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src 'self' wss://webhqv1.jrjr.com:39801; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  }
}
